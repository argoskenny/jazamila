{
  "name": "jazamila-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "DATABASE_URL=file:./test.db node prisma/ensure-sqlite.cjs && DATABASE_URL=file:./test.db prisma db push --force-reset --skip-generate && DATABASE_URL=file:./test.db node prisma/seed.cjs && DATABASE_URL=file:./test.db vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:prod": "node prisma/ensure-sqlite.cjs && prisma db push",
    "db:seed": "node prisma/seed.cjs",
    "db:setup": "node prisma/ensure-sqlite.cjs && prisma db push && node prisma/seed.cjs",
    "db:import:legacy:dry": "node scripts/import-legacy-mysql-to-sqlite.cjs --dry-run",
    "db:import:legacy": "node scripts/import-legacy-mysql-to-sqlite.cjs"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "mysql2": "^3.22.3",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
